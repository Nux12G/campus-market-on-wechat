.soft-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: 0 12rpx 30rpx rgba(100, 141, 166, 0.08);
}

.section-gap {
  margin-top: 28rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: var(--brand-primary-soft);
  color: var(--brand-primary-deep);
  font-size: 22rpx;
}
