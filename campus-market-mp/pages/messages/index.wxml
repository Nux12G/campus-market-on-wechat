<view class="messages-page">
  <view class="messages-hero">
    <view class="hero-pill">消息中心</view>
    <view class="hero-title">这里集中显示联系方式申请、处理结果和平台公告</view>
    <view class="hero-desc">当前阶段不提供聊天功能，卖家只需在这里完成同意或拒绝。</view>
  </view>

  <view wx:if="{{loading}}" class="state-card">
    <view class="state-title">消息加载中</view>
    <view class="state-text">正在同步你的申请和系统消息。</view>
  </view>

  <view wx:elif="{{loadFailed}}" class="state-card">
    <view class="state-title">消息加载失败</view>
    <view class="state-text">请下拉刷新或点击按钮重试。</view>
    <button class="retry-btn" bindtap="handleRetry">重新加载</button>
  </view>

  <view wx:else class="section-list">
    <view class="section-card">
      <view class="section-head">
        <view class="section-title">收到的申请</view>
        <view class="section-subtitle">卖家视角</view>
      </view>
      <block wx:if="{{groupedMessages.received.length}}">
        <view wx:for="{{groupedMessages.received}}" wx:key="id" class="message-card">
          <view class="message-head">
            <view class="message-type">联系方式申请</view>
            <view class="message-time">{{item.timeText}}</view>
          </view>
          <view class="message-title">{{item.title}}</view>
          <view class="message-content">{{item.content}}</view>
          <view wx:if="{{item.isUnread}}" class="unread-dot"></view>
          <view wx:if="{{item.status === 'pending'}}" class="action-row">
            <view class="action-btn approve-btn" data-id="{{item.relatedId}}" bindtap="handleApprove">同意</view>
            <view class="action-btn reject-btn" data-id="{{item.relatedId}}" bindtap="handleReject">拒绝</view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-text">暂无收到的申请</view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view class="section-title">我的申请结果</view>
        <view class="section-subtitle">买家视角</view>
      </view>
      <block wx:if="{{groupedMessages.result.length || groupedMessages.sent.length}}">
        <view wx:for="{{groupedMessages.result}}" wx:key="id" class="message-card">
          <view class="message-head">
            <view class="message-type">申请结果</view>
            <view class="message-time">{{item.timeText}}</view>
          </view>
          <view class="message-title">{{item.title}}</view>
          <view class="message-content">{{item.content}}</view>
          <view wx:if="{{item.isUnread}}" class="unread-dot"></view>
        </view>
        <view wx:for="{{groupedMessages.sent}}" wx:key="id" class="message-card">
          <view class="message-head">
            <view class="message-type">申请已发出</view>
            <view class="message-time">{{item.timeText}}</view>
          </view>
          <view class="message-title">{{item.title}}</view>
          <view class="message-content">{{item.content}}</view>
        </view>
      </block>
      <view wx:else class="empty-text">暂无申请结果</view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <view class="section-title">系统公告</view>
        <view class="section-subtitle">平台通知</view>
      </view>
      <block wx:if="{{groupedMessages.system.length}}">
        <view wx:for="{{groupedMessages.system}}" wx:key="id" class="message-card">
          <view class="message-head">
            <view class="message-type">公告</view>
            <view class="message-time">{{item.timeText}}</view>
          </view>
          <view class="message-title">{{item.title}}</view>
          <view class="message-content">{{item.content}}</view>
          <view wx:if="{{item.isUnread}}" class="unread-dot"></view>
        </view>
      </block>
      <view wx:else class="empty-text">暂无系统公告</view>
    </view>
  </view>
</view>
