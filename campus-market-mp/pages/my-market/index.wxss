.my-market-page {
  min-height: 100vh;
  padding: 18rpx 24rpx 120rpx;
  background:
    radial-gradient(circle at top right, rgba(142, 208, 255, 0.2), transparent 26%),
    linear-gradient(180deg, #f3fbff 0%, #f8fcff 44%, #ffffff 100%);
  box-sizing: border-box;
}

.my-market-hero {
  position: relative;
  overflow: hidden;
  padding: 30rpx 26rpx 42rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #9bd8ff 0%, #e0f5ff 100%);
}

.hero-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #2c6f92;
  font-size: 20rpx;
  font-weight: 600;
}

.hero-title {
  position: relative;
  z-index: 2;
  width: 84%;
  margin-top: 16rpx;
  font-size: 34rpx;
  line-height: 1.42;
  font-weight: 700;
  color: #1f516d;
}

.hero-desc {
  position: relative;
  z-index: 2;
  width: 80%;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.7;
  color: rgba(31, 81, 109, 0.8);
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
}

.hero-orb-lg {
  top: 20rpx;
  right: -28rpx;
  width: 150rpx;
  height: 150rpx;
}

.hero-orb-sm {
  top: 128rpx;
  right: 92rpx;
  width: 56rpx;
  height: 56rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.summary-card {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(96, 139, 162, 0.08);
}

.summary-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f6488;
}

.summary-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #7c98aa;
}

.market-list {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.market-card,
.status-card,
.empty-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(96, 139, 162, 0.08);
}

.cover-wrap {
  position: relative;
  width: 176rpx;
  height: 176rpx;
  flex-shrink: 0;
}

.market-cover {
  width: 100%;
  height: 100%;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #dff4ff 0%, #f4fbff 100%);
}

.campus-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  max-width: 144rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(24, 74, 100, 0.72);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1.2;
}

.market-content {
  min-width: 0;
  flex: 1;
}

.market-topline,
.market-bottomline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.market-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef9ff;
  color: #2d7093;
  font-size: 20rpx;
  font-weight: 600;
}

.market-meta {
  font-size: 20rpx;
  color: #8da4b4;
}

.market-title {
  display: -webkit-box;
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #254c65;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.market-id {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #8da4b4;
}

.market-desc {
  display: -webkit-box;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #7692a5;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.market-bottomline {
  margin-top: 16rpx;
}

.action-row {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 14rpx;
}

.edit-link,
.action-link {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.edit-link {
  background: #eef9ff;
  color: #2d7093;
}

.warn-link {
  background: #fff6df;
  color: #9a6a00;
}

.danger-link {
  background: #ffe9e3;
  color: #c95e4b;
}

.stats-line {
  font-size: 20rpx;
  color: #7d96a8;
}

.price-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.price-label {
  font-size: 18rpx;
  color: #8fa7b7;
}

.price-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f6488;
}

.status-card,
.empty-card {
  display: block;
}

.status-title,
.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #244b63;
}

.status-text,
.empty-text {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.8;
  color: #7c97a8;
}

.status-btn {
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #68c5ff 0%, #98ddff 100%);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 82rpx;
}

.status-btn::after {
  border: 0;
}

.publish-btn {
  position: fixed;
  right: 28rpx;
  bottom: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  min-width: 104rpx;
  min-height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #67c4ff 0%, #9cdeff 100%);
  color: #ffffff;
  font-size: 52rpx;
  line-height: 1;
  box-shadow: 0 18rpx 36rpx rgba(84, 176, 255, 0.28);
  box-sizing: border-box;
}

.skeleton-card {
  align-items: center;
}

.skeleton-cover,
.skeleton-line {
  border-radius: 20rpx;
  background: linear-gradient(90deg, #f1f7fb 0%, #e4eef5 50%, #f1f7fb 100%);
}

.skeleton-cover {
  width: 176rpx;
  height: 176rpx;
}

.skeleton-right {
  flex: 1;
}

.skeleton-line {
  height: 24rpx;
  margin-top: 18rpx;
}

.skeleton-line-lg {
  width: 86%;
  margin-top: 8rpx;
}

.skeleton-line-sm {
  width: 48%;
}
