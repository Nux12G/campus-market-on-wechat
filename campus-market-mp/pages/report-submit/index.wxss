.admin-sub-page{min-height:100vh;padding:20rpx 24rpx 40rpx;background:linear-gradient(180deg,#f4fbff 0%,#ffffff 100%);box-sizing:border-box;}
.card{padding:28rpx 26rpx;border-radius:30rpx;background:#fff;box-shadow:0 14rpx 34rpx rgba(96,139,162,.08);}
.title{font-size:32rpx;font-weight:700;color:#254c65;}
.sub-text{margin-top:10rpx;font-size:22rpx;color:#7c97a8;}
.input,.textarea{margin-top:22rpx;border-radius:22rpx;background:#f5fbfe;border:2rpx solid #dceef8;box-sizing:border-box;font-size:24rpx;color:#31556b;}
.input{height:88rpx;padding:0 24rpx;}
.textarea{width:100%;min-height:180rpx;padding:22rpx 24rpx;}
.submit-btn{margin-top:24rpx;border-radius:999rpx;background:linear-gradient(135deg,#ff8e6b 0%,#ffb08c 100%);color:#fff;font-size:28rpx;line-height:88rpx;}
.submit-btn::after{border:0;}
