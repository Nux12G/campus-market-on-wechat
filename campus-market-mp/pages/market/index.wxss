.market-page {
  min-height: 100vh;
  padding: 18rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at top left, rgba(142, 208, 255, 0.22), transparent 28%),
    linear-gradient(180deg, #f4fbff 0%, #f8fcff 46%, #ffffff 100%);
  box-sizing: border-box;
}

.market-hero {
  position: relative;
  overflow: hidden;
  padding: 30rpx 26rpx 40rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #90d5ff 0%, #d8f1ff 100%);
}

.hero-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #2c6f92;
  font-size: 20rpx;
  font-weight: 600;
}

.hero-title {
  position: relative;
  z-index: 2;
  width: 84%;
  margin-top: 16rpx;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #1d516d;
}

.hero-desc {
  position: relative;
  z-index: 2;
  width: 80%;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.7;
  color: rgba(29, 81, 109, 0.8);
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
}

.hero-orb-lg {
  top: 24rpx;
  right: -26rpx;
  width: 140rpx;
  height: 140rpx;
}

.hero-orb-sm {
  right: 90rpx;
  top: 120rpx;
  width: 52rpx;
  height: 52rpx;
}

.search-panel,
.filter-panel {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 30rpx rgba(94, 136, 160, 0.1);
}

.search-shell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  background: #f2f9fd;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  color: #274e67;
}

.search-action {
  min-width: 110rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #68c5ff 0%, #9adfff 100%);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 72rpx;
  text-align: center;
}

.search-action-disabled {
  background: #d8ecf8;
  color: #7d9aac;
}

.search-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 14rpx;
}

.search-status,
.search-clear {
  font-size: 21rpx;
  color: #7793a7;
}

.search-clear {
  color: #2c6f92;
  font-weight: 600;
}

.filter-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #5c8199;
}

.campus-scroll {
  margin-top: 14rpx;
  white-space: nowrap;
}

.campus-row {
  display: inline-flex;
  gap: 14rpx;
}

.campus-chip,
.sort-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #eef8ff;
  color: #63839a;
  font-size: 22rpx;
  white-space: nowrap;
}

.campus-chip-active,
.sort-chip-active {
  background: linear-gradient(135deg, #6cc6ff 0%, #9edfff 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(108, 198, 255, 0.2);
}

.sort-row {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.market-list {
  display: grid;
  gap: 18rpx;
  margin-top: 20rpx;
}

.market-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(96, 139, 162, 0.08);
}

.cover-wrap {
  position: relative;
  width: 188rpx;
  height: 188rpx;
  flex-shrink: 0;
}

.market-cover {
  width: 100%;
  height: 100%;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #dff4ff 0%, #f4fbff 100%);
}

.campus-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  max-width: 156rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(24, 74, 100, 0.72);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1.2;
}

.market-content {
  min-width: 0;
  flex: 1;
}

.market-topline,
.market-bottomline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.market-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef9ff;
  color: #2e7093;
  font-size: 20rpx;
  font-weight: 600;
}

.market-view {
  font-size: 20rpx;
  color: #8ca4b4;
}

.market-title {
  display: -webkit-box;
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #254c65;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.market-desc {
  display: -webkit-box;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #7692a5;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.market-bottomline {
  margin-top: 16rpx;
}

.market-meta {
  font-size: 20rpx;
  color: #8da4b4;
}

.market-price-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.market-price-label {
  font-size: 18rpx;
  color: #8fa7b7;
}

.market-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f6488;
}

.status-card {
  margin-top: 22rpx;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(96, 139, 162, 0.08);
}

.status-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #244b63;
}

.status-text {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.8;
  color: #7c97a8;
}

.status-btn {
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #68c5ff 0%, #98ddff 100%);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 82rpx;
}

.status-btn::after {
  border: 0;
}

.more-tip {
  padding: 22rpx 0 12rpx;
  text-align: center;
  font-size: 22rpx;
  color: #5f88a1;
}

.muted-tip {
  color: #92a7b6;
}

.skeleton-card {
  align-items: center;
}

.skeleton-cover,
.skeleton-line {
  border-radius: 20rpx;
  background: linear-gradient(90deg, #f1f7fb 0%, #e4eef5 50%, #f1f7fb 100%);
}

.skeleton-cover {
  width: 188rpx;
  height: 188rpx;
}

.skeleton-right {
  flex: 1;
}

.skeleton-line {
  height: 24rpx;
  margin-top: 18rpx;
}

.skeleton-line-lg {
  width: 86%;
  margin-top: 8rpx;
}

.skeleton-line-sm {
  width: 48%;
}
