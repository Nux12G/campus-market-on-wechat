.admin-sub-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #f4fbff 0%, #ffffff 100%);
  box-sizing: border-box;
}

.card,
.state-card {
  padding: 28rpx 26rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(96, 139, 162, 0.08);
}

.title,
.state-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #254c65;
}

.input {
  height: 88rpx;
  margin-top: 22rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f5fbfe;
  border: 2rpx solid #dceef8;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #31556b;
}

.submit-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffb26b 0%, #ffd08c 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 88rpx;
}

.submit-btn::after {
  border: 0;
}

.state-card,
.word-list {
  margin-top: 18rpx;
}

.word-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.word-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #eef9ff;
  color: #2d7093;
  font-size: 22rpx;
}
