.admin-sub-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #f4fbff 0%, #ffffff 100%);
  box-sizing: border-box;
}

.card,
.state-card,
.goods-card {
  padding: 28rpx 26rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(96, 139, 162, 0.08);
}

.state-card,
.goods-list {
  margin-top: 18rpx;
}

.title,
.state-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #254c65;
}

.sub-text,
.goods-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #7c97a8;
}

.search-input {
  height: 88rpx;
  margin-top: 22rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f5fbfe;
  border: 2rpx solid #dceef8;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #31556b;
}

.goods-list {
  display: grid;
  gap: 18rpx;
}

.goods-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.goods-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #254c65;
}

.goods-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef9ff;
  color: #2d7093;
  font-size: 20rpx;
}

.goods-price {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f6488;
}

.action-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.action-btn {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #ffe9e3;
  color: #c95e4b;
  font-size: 22rpx;
  font-weight: 600;
}
