.home-page {
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
  background:
    radial-gradient(circle at top right, rgba(142, 208, 255, 0.34), transparent 30%),
    linear-gradient(180deg, #f2fbff 0%, #f8fcff 42%, #ffffff 100%);
  box-sizing: border-box;
}

.home-hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx 26rpx 72rpx;
  border-bottom-left-radius: 42rpx;
  border-bottom-right-radius: 42rpx;
  background: linear-gradient(155deg, #83ceff 0%, #b5e7ff 54%, #e8f8ff 100%);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #2f6f92;
  font-size: 20rpx;
  font-weight: 600;
}

.hero-title {
  position: relative;
  z-index: 2;
  width: 86%;
  margin-top: 14rpx;
  font-size: 34rpx;
  line-height: 1.36;
  font-weight: 700;
  color: #194d68;
}

.hero-desc {
  position: relative;
  z-index: 2;
  width: 82%;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: rgba(25, 77, 104, 0.82);
}

.hero-stats {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 18rpx;
  margin-top: 16rpx;
}

.stat-card {
  min-width: 118rpx;
  padding: 12rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(8rpx);
  box-shadow: 0 10rpx 24rpx rgba(64, 127, 160, 0.1);
}

.stat-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f5977;
}

.stat-label {
  margin-top: 2rpx;
  font-size: 18rpx;
  color: #6a8aa0;
}

.hero-cloud {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
}

.hero-cloud-lg {
  top: 24rpx;
  right: -38rpx;
  width: 150rpx;
  height: 150rpx;
}

.hero-cloud-sm {
  top: 102rpx;
  right: 88rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.4);
}

.hero-wave {
  position: absolute;
  left: -10%;
  width: 120%;
  border-radius: 50%;
}

.hero-wave-top {
  bottom: -170rpx;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.38);
}

.hero-wave-bottom {
  bottom: -182rpx;
  height: 212rpx;
  background: rgba(255, 255, 255, 0.74);
}

.entry-section {
  position: relative;
  z-index: 3;
  display: grid;
  gap: 20rpx;
  margin: -32rpx 0 26rpx;
}

.entry-card {
  position: relative;
  overflow: hidden;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  box-shadow: 0 18rpx 42rpx rgba(89, 133, 156, 0.12);
}

.primary-entry {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(232, 248, 255, 0.98) 100%);
}

.secondary-entry {
  background: linear-gradient(135deg, #f8fdff 0%, #ffffff 100%);
}

.entry-tag,
.section-badge,
.goods-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.entry-tag {
  position: relative;
  z-index: 2;
  background: rgba(142, 208, 255, 0.18);
  color: #2d6f92;
  padding: 6rpx 12rpx;
  font-size: 18rpx;
}

.entry-title {
  position: relative;
  z-index: 2;
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #20445d;
}

.entry-desc {
  position: relative;
  z-index: 2;
  width: 72%;
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.6;
  color: #6f8ba0;
}

.entry-link {
  position: relative;
  z-index: 2;
  margin-top: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #2a6f92;
}

.entry-shape {
  position: absolute;
  right: -28rpx;
  bottom: -28rpx;
  border-radius: 32rpx;
  transform: rotate(-18deg);
}

.entry-shape-a {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(180deg, rgba(142, 208, 255, 0.16) 0%, rgba(142, 208, 255, 0.32) 100%);
}

.entry-shape-b {
  width: 98rpx;
  height: 98rpx;
  background: linear-gradient(180deg, rgba(255, 215, 106, 0.2) 0%, rgba(255, 215, 106, 0.34) 100%);
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 0 6rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #20465f;
}

.section-subtitle {
  width: 460rpx;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #7693a6;
}

.section-badge {
  margin-top: 8rpx;
  background: #eef9ff;
  color: #2d6f92;
}

.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 24rpx;
}

.goods-card {
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(96, 139, 162, 0.1);
}

.guide-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 360rpx;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fffaf0 0%, #ffffff 100%);
  box-shadow: 0 14rpx 34rpx rgba(96, 139, 162, 0.08);
}

.goods-cover-wrap {
  position: relative;
}

.goods-cover {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #dff4ff 0%, #f4fbff 100%);
}

.goods-campus {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  max-width: 156rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(24, 74, 100, 0.72);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1.2;
}

.goods-content {
  padding: 20rpx 20rpx 22rpx;
}

.goods-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.goods-tag {
  max-width: 130rpx;
  background: #eef9ff;
  color: #2e7093;
}

.goods-tag-new {
  background: #fff1dc;
  color: #a96a06;
}

.goods-category {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #7f9aad;
}

.goods-views {
  font-size: 20rpx;
  color: #8ca4b4;
}

.goods-title {
  display: -webkit-box;
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #264d66;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-meta {
  margin-top: 12rpx;
  font-size: 21rpx;
  color: #87a0b0;
}

.goods-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.goods-price-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.goods-price-label {
  font-size: 18rpx;
  color: #8fa7b7;
}

.goods-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f6488;
}

.goods-link {
  font-size: 22rpx;
  color: #6d95ad;
}

.guide-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1dc;
  color: #a96a06;
  font-size: 20rpx;
  font-weight: 600;
}

.guide-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #6a4a09;
}

.guide-text {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #8b723e;
}

.guide-link {
  margin-top: 22rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #9a6a00;
}

.status-card {
  margin-top: 24rpx;
  padding: 34rpx 30rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(96, 139, 162, 0.08);
}

.status-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #244b63;
}

.status-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #7c97a8;
}

.status-btn {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #68c5ff 0%, #98ddff 100%);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 84rpx;
}

.status-btn::after {
  border: 0;
}

.skeleton-card {
  padding: 18rpx;
}

.skeleton-cover,
.skeleton-line {
  border-radius: 22rpx;
  background: linear-gradient(90deg, #f1f7fb 0%, #e4eef5 50%, #f1f7fb 100%);
}

.skeleton-cover {
  height: 220rpx;
}

.skeleton-line {
  height: 24rpx;
  margin-top: 16rpx;
}

.skeleton-line-lg {
  width: 88%;
}

.skeleton-line-sm {
  width: 54%;
}
