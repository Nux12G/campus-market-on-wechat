<view class="profile-page">
  <view class="profile-hero">
    <view class="hero-tag">个人设置</view>
    <view class="hero-title">在这里维护你的头像、昵称和联系方式，让交易信息更清晰</view>
    <view class="hero-desc">后续管理员入口也会放在这里，但只对管理员身份显示。</view>
  </view>

  <view class="profile-card">
    <view class="avatar-shell" bindtap="handleGoAvatar">
      <view class="avatar-circle">
        <image wx:if="{{userInfo && userInfo.avatarUrl}}" class="avatar-image" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="avatar-fallback">{{userInfo && userInfo.nickname ? userInfo.nickname.slice(0, 1) : '集'}}</view>
      </view>
      <view class="avatar-info">
        <view class="avatar-name">{{userInfo && userInfo.nickname ? userInfo.nickname : '校园用户'}}</view>
        <view class="avatar-id">校园编号：{{userInfo && userInfo.userNo ? userInfo.userNo : '--'}}</view>
      </view>
      <view class="avatar-link">修改头像</view>
    </view>
  </view>

  <view class="setting-list">
    <view class="setting-item" bindtap="handleGoNickname">
      <view>
        <view class="setting-title">修改昵称</view>
        <view class="setting-desc">更新你在商品页和申请记录中的展示名称</view>
      </view>
      <view class="setting-link">进入</view>
    </view>

    <view class="setting-item" bindtap="handleGoContact">
      <view>
        <view class="setting-title">修改联系方式</view>
        <view class="setting-desc">调整联系方式类型与内容，后续申请通过后将展示给买家</view>
      </view>
      <view class="setting-link">进入</view>
    </view>

    <view wx:if="{{userInfo && userInfo.role === 9}}" class="setting-item admin-item" bindtap="handleGoAdmin">
      <view>
        <view class="setting-title">管理员入口</view>
        <view class="setting-desc">进入后台管理中心，处理账号封禁和商品强制下架</view>
      </view>
      <view class="setting-link">进入</view>
    </view>
  </view>
</view>
