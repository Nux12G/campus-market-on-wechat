.profile-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at top right, rgba(142, 208, 255, 0.18), transparent 24%),
    linear-gradient(180deg, #f4fbff 0%, #f8fcff 42%, #ffffff 100%);
  box-sizing: border-box;
}

.profile-hero,
.profile-card,
.setting-item {
  padding: 28rpx 26rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(96, 139, 162, 0.08);
}

.profile-hero {
  background: linear-gradient(145deg, #9fdcff 0%, #e4f6ff 100%);
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #2d6f92;
  font-size: 20rpx;
  font-weight: 600;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 34rpx;
  line-height: 1.42;
  font-weight: 700;
  color: #1f516d;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.7;
  color: rgba(31, 81, 109, 0.8);
}

.profile-card,
.setting-list {
  margin-top: 18rpx;
}

.avatar-shell {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar-circle {
  overflow: hidden;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #67c4ff 0%, #9cdeff 100%);
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
}

.avatar-info {
  flex: 1;
}

.avatar-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #244d65;
}

.avatar-id {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7c97a8;
}

.avatar-link,
.setting-link {
  color: #2d7093;
  font-size: 22rpx;
  font-weight: 600;
}

.setting-list {
  display: grid;
  gap: 18rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.admin-item {
  background: linear-gradient(135deg, #fff7e0 0%, #ffffff 100%);
}

.setting-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #254c65;
}

.setting-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #7b97a8;
}
