.detail-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 150rpx;
  background:
    radial-gradient(circle at top right, rgba(142, 208, 255, 0.18), transparent 24%),
    linear-gradient(180deg, #f4fbff 0%, #f8fcff 40%, #ffffff 100%);
  box-sizing: border-box;
}

.detail-swiper {
  overflow: hidden;
  height: 520rpx;
  border-radius: 34rpx;
  box-shadow: 0 18rpx 42rpx rgba(96, 139, 162, 0.12);
}

.detail-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #dff4ff 0%, #f4fbff 100%);
}

.detail-main,
.detail-section,
.status-card,
.detail-card {
  margin-top: 22rpx;
  padding: 30rpx 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(96, 139, 162, 0.08);
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.chip-group {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.price-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.price-label {
  font-size: 20rpx;
  color: #8ea5b4;
}

.price-text {
  font-size: 50rpx;
  font-weight: 700;
  color: #1e6387;
}

.tag-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef9ff;
  color: #2c6f92;
  font-size: 22rpx;
  font-weight: 600;
}

.campus-chip {
  background: #244b63;
  color: #ffffff;
}

.title-text {
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #244b63;
}

.meta-text {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #7b97a8;
}

.goods-id {
  margin-top: 10rpx;
  font-size: 21rpx;
  color: #8ca4b4;
}

.metric-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.metric-card {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f3fbff 0%, #ffffff 100%);
}

.metric-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #22536f;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #8aa2b2;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #234c64;
}

.section-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.9;
  color: #68879b;
}

.seller-card {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #f5fbff 0%, #ffffff 100%);
}

.seller-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.seller-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #67c4ff 0%, #9cdeff 100%);
  flex-shrink: 0;
}

.seller-avatar-image {
  width: 100%;
  height: 100%;
}

.seller-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.seller-main {
  flex: 1;
}

.seller-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(142, 208, 255, 0.2);
  color: #2c6f92;
  font-size: 20rpx;
  font-weight: 600;
}

.seller-name {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #244d65;
}

.seller-id,
.seller-tip,
.status-text {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.8;
  color: #7c97a8;
}

.seller-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 30rpx;
  border-radius: 999rpx;
  background: #eef9ff;
  color: #2d7093;
  font-size: 24rpx;
  font-weight: 600;
}

.seller-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.report-link {
  background: #ffe9e3;
  color: #c95e4b;
}

.status-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #244b63;
}

.status-btn {
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #68c5ff 0%, #98ddff 100%);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 82rpx;
}

.status-btn::after {
  border: 0;
}

.action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 18rpx 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 40rpx rgba(88, 129, 151, 0.18);
  backdrop-filter: blur(10rpx);
}

.action-note {
  flex: 1;
  font-size: 21rpx;
  line-height: 1.6;
  color: #6e8ca0;
}

.want-btn {
  min-width: 200rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #67c4ff 0%, #9cdeff 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 84rpx;
}

.want-btn-disabled {
  background: #d9eaf4;
  color: #6f8ea1;
}

.want-btn::after {
  border: 0;
}

.detail-loading {
  display: grid;
  gap: 22rpx;
}

.skeleton-banner,
.skeleton-block {
  background: linear-gradient(90deg, #f1f7fb 0%, #e4eef5 50%, #f1f7fb 100%);
}

.skeleton-banner {
  height: 520rpx;
}

.skeleton-block {
  height: 200rpx;
}

.skeleton-block-lg {
  height: 280rpx;
}
