@import "./styles/variables.wxss";
@import "./styles/theme.wxss";

page {
  min-height: 100%;
  background: var(--page-bg);
  color: var(--text-primary);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero-panel {
  position: relative;
  overflow: hidden;
  padding: 36rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eaf8ff 100%);
  box-shadow: 0 12rpx 36rpx rgba(93, 154, 194, 0.12);
}

.hero-panel::after {
  content: "";
  position: absolute;
  right: -48rpx;
  top: -32rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(142, 208, 255, 0.2);
}

.page-title {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.page-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.placeholder-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(100, 141, 166, 0.08);
}

.placeholder-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.placeholder-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}
